\@writefile{toc}{\contentsline {paragraph}{Accuracy Breakdown by Dataset.}{7}{section*.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Multi-hop accuracy for each method across three dataset types: Synthetic (8 tasks, 2--3 hop kinship), CLUTRR-style (5 tasks, multi-hop family relations), RuleTaker-style (5 tasks, depth-1 to depth-3 deduction). RFDE excels on synthetic (87.5\%) where demand-driven extraction prevents over-generation, but struggles on RuleTaker (20\%) where implicit reasoning across rule chains is required. CoT maintains 83.3--100\% across all datasets, suggesting holistic document reasoning is more robust for complex inference.}}{8}{figure.caption.9}\protected@file@percent }
\newlabel{fig:accuracy-by-dataset}{{2}{8}{Multi-hop accuracy for each method across three dataset types: Synthetic (8 tasks, 2--3 hop kinship), CLUTRR-style (5 tasks, multi-hop family relations), RuleTaker-style (5 tasks, depth-1 to depth-3 deduction). RFDE excels on synthetic (87.5\%) where demand-driven extraction prevents over-generation, but struggles on RuleTaker (20\%) where implicit reasoning across rule chains is required. CoT maintains 83.3--100\% across all datasets, suggesting holistic document reasoning is more robust for complex inference}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {paragraph}{LLM Call Efficiency.}{8}{section*.10}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Proof Trace Auditability.}{8}{section*.12}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Left: Average number of LLM calls per task. RFDE: 3.61 calls (demand-driven extraction). CoT, RAG, Eager FOL: 1.0 call each. Right: Cost per task in USD. RFDE: \$0.00013 (multiple targeted calls to ground specific predicates). CoT: \$0.00004 (single holistic query). Total cost across 18 tasks: \$0.0053 USD for all methods combined, well within \$8 budget. The higher call count yields auditable proof traces and structural hallucination reduction.}}{9}{figure.caption.11}\protected@file@percent }
\newlabel{fig:efficiency}{{3}{9}{Left: Average number of LLM calls per task. RFDE: 3.61 calls (demand-driven extraction). CoT, RAG, Eager FOL: 1.0 call each. Right: Cost per task in USD. RFDE: \$0.00013 (multiple targeted calls to ground specific predicates). CoT: \$0.00004 (single holistic query). Total cost across 18 tasks: \$0.0053 USD for all methods combined, well within \$8 budget. The higher call count yields auditable proof traces and structural hallucination reduction}{figure.caption.11}{}}
